      m_Calls: []
  m_text: "\u203B\uC870\uC791\uBC95\n\uC774\uB3D9 : W,A,S,D & \uBC29\uD5A5\uD0A4
    / \uC870\uC0AC : Enter & Z\uD0A4\n\n\n\uC774 \uAC8C\uC784\uC740 \uC0AC\uB791\uD558\uB294
    \uC5F0\uC778\uC5D0\uAC8C \uCD5C\uACE0\uC758 \uC0DD\uC77C \uCF00\uC774\uD06C\uB97C
    \uC120\uBB3C\uD558\uAE30 \uC704\uD574 5\uAC00\uC9C0\uC758 \uCF00\uC774\uD06C
    \uC7AC\uB8CC\uB97C \uBAA8\uC73C\uB294 \uAC8C\uC784\uC73C\uB85C,\n\uC2DC\uC791
    \uC2DC \uCAD2\uC544\uC624\uB294 \uC801\uC744 \uD53C\uD574 \uAC01 \uC7A5\uC18C\uC5D0
    \uD769\uC5B4\uC838\uC788\uB294 \uC7AC\uB8CC\uB97C \uBAA8\uC544\uC57C \uD558\uBA70,
    \uC804\uBD80 \uBAA8\uC544 \uACE8\uC778 \uC9C0\uC810\uC5D0 \uB3C4\uB2EC \uC2DC
    \uD074\uB9AC\uC5B4 \uC2DC\uAC04\uC5D0 \uB530\uB77C \uC5D4\uB529\uC774 \uBC14\uB01D\uB2C8\uB2E4.\n\n\uC801\uC744
    \uD53C\uD574 \uBE60\uB974\uAC8C \uCF00\uC774\uD06C \uC7AC\uB8CC\uB97C \uBAA8\uC73C\uB294
    \uAC83\uC774 \uAD00\uAC74\uC785\uB2C8\uB2E4. \uD654\uC774\uD305!\n\n"
  m_isRightToLeft: 0
